# Token del bot — lo da @BotFather en Telegram
TELEGRAM_BOT_TOKEN=7234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tu Chat ID personal — lo da @userinfobot en Telegram
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Puerto del servidor HTTP
PORT=3000

# Clave secreta que va a usar tu app FinanzAR para autenticarse
# Elegí cualquier string largo y aleatorio, por ejemplo: openssl rand -hex 32
API_KEY=cambia_esto_por_una_clave_secreta_larga
